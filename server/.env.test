NODE_ENV=test

AUTH_PORT=3101
PROJECT_PORT=3102
TASK_PORT=3103
NOTIFICATION_PORT=3104
GATEWAY_PORT=3100

RUN_MYSQL_TESTS=1
SQLITE_DB_LOCATION=./test_outputs/test.db

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=test_user
MYSQL_ROOT_PASSWORD=test_password
MYSQL_DATABASE=test_todos

JWT_SECRET=test_secret_key
JWT_EXPIRES_IN=1d

REDIS_HOST=localhost
REDIS_PORT=6379
BUS_PREFIX=test

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=test@todo.local
NOTIFY_FALLBACK_TO=test-user@todo.local
NOTIFY_DRY_RUN=1

AUTH_SERVICE_URL=http://localhost:3101
PROJECT_SERVICE_URL=http://localhost:3102
TASK_SERVICE_URL=http://localhost:3103
NOTIFICATION_SERVICE_URL=http://localhost:3104
