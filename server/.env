NODE_ENV=development

GATEWAY_PORT=3000
AUTH_PORT=3001
PROJECT_PORT=3002
TASK_PORT=3003
NOTIFICATION_PORT=3004

DB_DRIVER=sqlite

SQLITE_DB_LOCATION=./var/todo.db

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=test_user
MYSQL_PASSWORD=test_password
MYSQL_DATABASE=test_todos

JWT_SECRET=super_secret_key
JWT_EXPIRES_IN=7d

REDIS_HOST=localhost
REDIS_PORT=6379

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@todo.local
NOTIFY_FALLBACK_TO=stub-user@todo.local
NOTIFY_DRY_RUN=0

AUTH_SERVICE_URL=http://localhost:3001
PROJECT_SERVICE_URL=http://localhost:3002
TASK_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
