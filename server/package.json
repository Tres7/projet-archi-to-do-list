{
    "name": "101-app",
    "version": "1.0.0",
    "main": "index.js",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs",
        "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --coverage",
        "dev:gateway": "tsx apps/gateway/index.ts",
        "dev:auth": "tsx apps/auth-service/src/index.ts",
        "dev:project": "tsx apps/project-service/src/index.ts",
        "dev:task": "tsx apps/task-service/src/index.ts",
        "dev:notification": "tsx apps/notification-service/src/index.ts",
        "dev:all": "concurrently -n gateway,auth,project,task,notification \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:project\" \"npm run dev:task\" \"npm run dev:notification\"",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/apps/gateway/index.js",
        "validate:architecture": "npx depcruise apps common --config .dependency-cruiser.cjs",
        "dev:infra": "docker compose up -d db redis mailpit",
        "dev:infra:down": "docker compose down",
        "dev:infra:clean": "docker compose down -v --rmi all --remove-orphans"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "bullmq": "^5.70.1",
        "dotenv": "^17.2.4",
        "express": "^5.2.1",
        "http-proxy-middleware": "^3.0.5",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "mysql2": "^3.16.3",
        "nodemailer": "^8.0.1",
        "sqlite3": "^5.1.7",
        "uuid": "^13.0.0",
        "wait-port": "^1.1.0"
    },
    "overrides": {
        "ansi-regex": "5.0.1",
        "tar": "^7.5.7"
    },
    "resolutions": {
        "ansi-regex": "5.0.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.10.12",
        "@types/nodemailer": "^7.0.11",
        "@types/supertest": "^6.0.3",
        "concurrently": "^9.2.1",
        "dependency-cruiser": "^17.3.8",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eventsource": "^4.1.0",
        "globals": "^17.3.0",
        "jest": "^30.2.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
