{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "src",
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "verbatimModuleSyntax": true,
        "allowJs": true,
        "checkJs": false
    },
    "include": [
        "src/**/*",
        "../../common",
        "../../express"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}
