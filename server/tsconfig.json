{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": ".",
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "verbatimModuleSyntax": true,
        "allowJs": true,
        "checkJs": false
    },
    "include": [
        "apps/task-service/src/**/*",
        "server/src/index.ts",
        "types/express",
        "server/common/**/*.ts",
        "common/messaging/bullmq.types.ts"
, "apps/project-service/src/domain", "apps/project-service/src/infrastructure"    ],
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}
