{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": ".",
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "verbatimModuleSyntax": true,
        "allowJs": true,
        "checkJs": false
    },
    "include": [
        "apps/**/*",
        "common/**/*",
        "spec/**/*",
        "types/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}
