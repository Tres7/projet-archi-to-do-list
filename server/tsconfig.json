{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,
    "esModuleInterop": true,

    "outDir": "dist",
    "rootDir": "src",

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "allowJs": true,
    "checkJs": false
  },
  "include": ["src/**/*", "server/src/persistence", "server/src/routes", "server/src/todoTypes.ts", "server/src/index.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
