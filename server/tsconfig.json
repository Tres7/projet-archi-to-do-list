{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "paths": {
            "@app/common/*": ["./common/*.ts"]
        }
    },
    "include": [
        "apps/**/*",
        "common/**/*",
        "spec/**/*",
        "types/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}
